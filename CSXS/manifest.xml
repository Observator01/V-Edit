<?xml version="1.0" encoding="UTF-8"?>
<!-- V-Edit CEP extension manifest. Premiere Pro (PPRO). Node.js enabled for AI + file work. -->
<ExtensionManifest Version="11.0" ExtensionBundleId="com.observator01.vedit"
    ExtensionBundleVersion="0.3.4" ExtensionBundleName="V-Edit"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.observator01.vedit.panel" Version="0.3.4"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 24+ (covers 24/25/26). PPRO host id. -->
      <Host Name="PPRO" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList><Locale Code="All"/></LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.observator01.vedit.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <!-- Node.js + cross-domain for AI REST (ElevenLabs/Anthropic) -->
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-file-access</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>V-Edit</Menu>
          <Geometry>
            <Size><Height>560</Height><Width>340</Width></Size>
            <MinSize><Height>360</Height><Width>280</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
